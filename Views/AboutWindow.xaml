<Window x:Class="WhatKey.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About WhatKey"
        Width="380" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">

    <Border Background="#1E1E2E"
            BorderBrush="#313244"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="#181825"
                    CornerRadius="8,8,0,0"
                    Padding="14,10"
                    MouseDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <DockPanel>
                    <TextBlock Text="About" Foreground="#6C7086" FontSize="12"
                               DockPanel.Dock="Right" VerticalAlignment="Center"/>
                    <TextBlock Text="WhatKey" Foreground="#CDD6F4"
                               FontSize="14" FontWeight="SemiBold"/>
                </DockPanel>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="24,0">

                <TextBlock Text="WhatKey"
                           Foreground="#89B4FA"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Version 1.0"
                           Foreground="#6C7086"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <Rectangle Height="1" Fill="#313244" Margin="0,0,0,16"/>

                <TextBlock Text="Hotkey overlay for Windows"
                           Foreground="#CDD6F4"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
            </StackPanel>

            <!-- Bottom bar with close button -->
            <Border Grid.Row="2"
                    Background="#181825"
                    CornerRadius="0,0,8,8"
                    Padding="14,10">
                <Button Content="Close"
                        Width="80"
                        Height="28"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#313244"/>
                            <Setter Property="Foreground" Value="#CDD6F4"/>
                            <Setter Property="BorderBrush" Value="#45475A"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#45475A"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#585B70"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
