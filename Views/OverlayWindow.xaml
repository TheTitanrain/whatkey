<Window x:Class="WhatKey.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WhatKey.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        MinWidth="420"
        MaxHeight="650">

    <Window.Resources>
        <converters:KeyTokensConverter x:Key="KeyTokens"/>
    </Window.Resources>

    <Border Background="#CC1E1E2E"
            CornerRadius="12"
            Padding="28,20"
            MaxWidth="980">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,14">
                <TextBlock Text="WhatKey" Foreground="#6C7086" FontSize="11"
                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AppTitle}" Foreground="#CDD6F4"
                           FontSize="17" FontWeight="Bold"/>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#313244" Margin="0,0,0,14"/>

            <!-- Groups list -->
            <ScrollViewer x:Name="HotkeysScrollViewer"
                          MaxHeight="{Binding HotkeysListMaxHeight}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group header -->
                                <DockPanel Margin="0,8,0,4">
                                    <Rectangle Height="1" Fill="#313244" VerticalAlignment="Center"
                                               Margin="8,0,0,0" DockPanel.Dock="Right"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#6C7086"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </DockPanel>
                                <!-- Group hotkeys -->
                                <ItemsControl ItemsSource="{Binding Hotkeys}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding DataContext.OverlayColumns, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=1}"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,10,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Background="#313244" CornerRadius="5"
                                                        Padding="8,3" Grid.Column="0" Margin="0,0,14,0"
                                                        HorizontalAlignment="Left">
                                                    <ItemsControl ItemsSource="{Binding Keys, Converter={StaticResource KeyTokens}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Text}"
                                                                           Foreground="{Binding Brush}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="12"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>

                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#CDD6F4"
                                                           FontSize="12"
                                                           Grid.Column="1"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Text="No hotkeys defined for this application."
                       Foreground="#6C7086" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,8"
                       Visibility="{Binding EmptyMessageVisibility}"/>

            <!-- System hotkeys section -->
            <StackPanel Visibility="{Binding SystemSectionVisible}">
                <DockPanel Margin="0,10,0,6">
                    <TextBlock Text="SYSTEM" Foreground="#45475A"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Rectangle Height="1" Fill="#313244" VerticalAlignment="Center"
                               Margin="8,0,0,0"/>
                </DockPanel>
                <ItemsControl ItemsSource="{Binding SystemGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <DockPanel Margin="0,8,0,4">
                                    <Rectangle Height="1" Fill="#313244" VerticalAlignment="Center"
                                               Margin="8,0,0,0" DockPanel.Dock="Right"/>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#6C7086"
                                               FontSize="10"
                                               FontWeight="SemiBold"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Hotkeys}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding DataContext.OverlayColumns, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=1}"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3,10,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Background="#313244" CornerRadius="5"
                                                        Padding="8,3" Grid.Column="0" Margin="0,0,14,0"
                                                        HorizontalAlignment="Left">
                                                    <ItemsControl ItemsSource="{Binding Keys, Converter={StaticResource KeyTokens}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <StackPanel Orientation="Horizontal"/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Text}"
                                                                           Foreground="{Binding Brush}"
                                                                           FontFamily="Consolas"
                                                                           FontSize="12"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#CDD6F4"
                                                           FontSize="12"
                                                           Grid.Column="1"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Text="Hold key to keep open  ·  Esc to close"
                       Foreground="#45475A" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,14,0,0"/>
        </StackPanel>
    </Border>
</Window>
