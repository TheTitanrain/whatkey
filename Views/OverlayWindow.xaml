<Window x:Class="WhatKey.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        MaxHeight="650">

    <Border Background="#CC1E1E2E"
            CornerRadius="12"
            Padding="28,20"
            MinWidth="420"
            MaxWidth="980">
        <StackPanel>
            <!-- Header -->
            <DockPanel Margin="0,0,0,14">
                <TextBlock Text="WhatKey" Foreground="#6C7086" FontSize="11"
                           DockPanel.Dock="Right" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AppTitle}" Foreground="#CDD6F4"
                           FontSize="17" FontWeight="Bold"/>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Height="1" Fill="#313244" Margin="0,0,0,14"/>

            <!-- Hotkeys list -->
            <ScrollViewer MaxHeight="460"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Hotkeys}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="{Binding OverlayColumns, FallbackValue=1}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3,10,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#313244" CornerRadius="5"
                                        Padding="8,3" Grid.Column="0" Margin="0,0,14,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Keys}"
                                               Foreground="#89DCEB"
                                               FontFamily="Consolas"
                                               FontSize="12"/>
                                </Border>

                                <TextBlock Text="{Binding Description}"
                                           Foreground="#CDD6F4"
                                           FontSize="12"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock Text="No hotkeys defined for this application."
                       Foreground="#6C7086" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,8"
                       Visibility="{Binding EmptyMessageVisibility}"/>

            <!-- Footer -->
            <TextBlock Text="Hold key to keep open  ·  Esc to close"
                       Foreground="#45475A" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,14,0,0"/>
        </StackPanel>
    </Border>
</Window>
